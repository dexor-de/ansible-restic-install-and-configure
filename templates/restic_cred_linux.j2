#!/usr/bin/env bash
# {{ ansible_managed }}
# Backup credentials for {{ restic_user }}
# Source this file to work with restic on this host

export RESTIC_REPOSITORY={{ restic_exports.location }}
export RESTIC_PASSWORD='{{ restic_exports.password }}'
{% if restic_exports.aws_access_key is defined %}
export AWS_ACCESS_KEY_ID={{ restic_exports.aws_access_key }}
{% endif %}
{% if restic_exports.aws_secret_access_key is defined %}
export AWS_SECRET_ACCESS_KEY='{{ restic_exports.aws_secret_access_key }}'
{% endif %}

